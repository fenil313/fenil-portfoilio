    <body>
        <div id="tsparticles"><canvas data-generated="true" style="width: 100% !important; height: 100% !important; position: fixed !important; z-index: 0 !important; top: 0px !important; left: 0px !important; background-image: radial-gradient(rgb(74, 0, 0), rgb(0, 0, 0)); pointer-events: none;" aria-hidden="true" height="912" width="1920"></canvas></div>
        <script src="./tsParticles _ Fire Preset _ JavaScript Particles, Confetti and Fireworks animations for your website_files/tsparticles.preset.fire.bundle.min.js.download"></script>
        <script type="text/javascript">
            (async (engine) => {
                await loadFirePreset(engine);

                await engine.load({ id: "tsparticles", options: { preset: "fire" } });
            })(tsParticles);
        </script>
    

